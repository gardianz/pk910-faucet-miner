# which faucet(s) to mine — comma separated: sepolia, ephemery, hoodi (pick 1, 2, or all 3)
FAUCETS=sepolia
# optional per-faucet URL overrides (defaults to the public pk910 instances)
SEPOLIA_URL=https://sepolia-faucet.pk910.de
EPHEMERY_URL=https://ephemery-faucet.pk910.de
HOODI_URL=https://hoodi-faucet.pk910.de

FAUCET_CLIVER=2.4.0

# Captcha solver: "multibot" (default) atau "2captcha" — protokol sama, beda host/key.
# Isi API key sesuai provider yang dipilih.
CAPTCHA_PROVIDER=multibot
MULTIBOT_APIKEY=replace-me-rotate-the-leaked-key
TWOCAPTCHA_APIKEY=

# Opsional: kalau Chromium error "libnspr4.so: cannot open shared object file"
# (WSL/container tanpa root), tunjuk ke folder lib hasil ekstrak. Kosongkan jika
# sudah `sudo npx playwright install-deps chromium`.
CHROME_LIBS_PATH=

# Mode jalan: "forever" (default, untuk VPS 24 jam: mine -> claim -> ulang) atau "once".
LOOP=forever
# Jeda antar ronde (detik) saat LOOP=forever. Default 30.
LOOP_DELAY_SEC=30

# Kapan auto-claim. Pilih SALAH SATU (CLAIM_THRESHOLD_WEI menang jika dua-duanya diisi).
# Kosong dua-duanya = claim begitu mencapai minClaim faucet (paling cepat).
CLAIM_THRESHOLD_WEI=          # jumlah absolut dalam wei (1 ETH = 1000000000000000000)
CLAIM_PERCENT=               # % dari maxClaim faucet, 1..100 (mis. 50 = tambang sampai 50% maxClaim)

WALLET_1_ADDR=0x0000000000000000000000000000000000000000
WALLET_1_PROXY=
WALLET_2_ADDR=0x0000000000000000000000000000000000000000
WALLET_2_PROXY=
WALLET_3_ADDR=0x0000000000000000000000000000000000000000
WALLET_3_PROXY=
